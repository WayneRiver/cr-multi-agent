# 阿里云百炼配置
# API Key：在阿里云百炼控制台获取
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# API 地址：使用兼容模式
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 模型名称：可选 qwen-max / qwen-plus / qwen-turbo
LLM_MODEL=qwen-plus

# Redis
REDIS_URL=redis://localhost:6379
CACHE_TTL_DAYS=7

# GitHub
GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Agent 超时（秒）
STYLE_CHECKER_TIMEOUT=10
SECURITY_CHECKER_TIMEOUT=10
LOGIC_CHECKER_TIMEOUT=15
READABILITY_CHECKER_TIMEOUT=10

# 降级阈值
DEGRADATION_THRESHOLD=2

# 日志级别
LOG_LEVEL=INFO
